{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "setupFiles": ["<rootDir>/e2e-setup.ts"],
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@common$": "<rootDir>/../src/common",
    "^@config$": "<rootDir>/../src/configs",
    "^@module$": "<rootDir>/../src/modules",
    "^@shared$": "<rootDir>/../src/modules/shared"
  }
}
