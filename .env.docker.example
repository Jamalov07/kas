# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0

# ─── PDF (invoice logo) ───────────────────────────────────────────────────────
# jas | kas — docker-compose app.environment orqali ham beriladi
PDF_LOGO_BRAND=jas

# ─── Database (Docker Compose internal) ──────────────────────────────────────
# Bu qiymatlarni o'zgartiring
DB_USER=jas_user
DB_PASSWORD=strong_password_here
DB_NAME=jas_db

# DATABASE_URL docker-compose.yml ichida avtomatik yasaladi:
# postgresql://DB_USER:DB_PASSWORD@db:5432/DB_NAME
# Agar to'g'ridan-to'g'ri bermoqchi bo'lsangiz:
# DATABASE_URL=postgresql://jas_user:strong_password_here@db:5432/jas_db

# ─── JWT ─────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_KEY=your_very_secret_access_key_here
ACCESS_TOKEN_TIME=15m
REFRESH_TOKEN_KEY=your_very_secret_refresh_key_here
REFRESH_TOKEN_TIME=7d

# ─── Telegram Bot ─────────────────────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here
SELLING_CHANNEL_ID=-100xxxxxxxxx
PAYMENT_CHANNEL_ID=-100xxxxxxxxx
