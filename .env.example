# PDF invoice logo: jas | kas. Docker: docker-compose `PDF_LOGO_BRAND` (default u yerda jas).
# Agar PDF_LOGO_BRAND bo‘lmasa: legacy `APP=jas` → jas logo, aks holda kas.
PDF_LOGO_BRAND=jas

# app (Nest listen). Docker: HOST=0.0.0.0 PORT=3000 — docker-compose sets these.
PORT=
HOST=
# optional overrides (if set, used instead of HOST/PORT above)
# APP_HOST=
# APP_PORT=

#db
DATABASE_URL=

#jwt
REFRESH_TOKEN_TIME=
REFRESH_TOKEN_KEY=
ACCESS_TOKEN_TIME=
ACCESS_TOKEN_KEY=

#bot
BOT_TOKEN=
SELLING_CHANNEL_ID=
PAYMENT_CHANNEL_ID=

# e2e (optional — enables `test/api-smoke.e2e-spec.ts` staff token checks)
# E2E_STAFF_PHONE=
# E2E_STAFF_PASSWORD=
